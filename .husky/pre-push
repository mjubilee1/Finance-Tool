#!/usr/bin/env sh

branch_from_ref() {
  printf "%s" "$1" | sed 's#^refs/heads/##'
}

while read -r local_ref local_sha remote_ref remote_sha; do
  if [ "$remote_ref" = "refs/heads/main" ]; then
    node scripts/bump-version.mjs
    code=$?

    if [ "$code" -eq 2 ]; then
      branch=$(branch_from_ref "$local_ref")
      echo "Pushing v$(node -p "require('./package.json').version") to origin/$branch..."
      SKIP_VERSION_BUMP=1 git push --no-verify origin "$branch" --follow-tags
      exit $?
    fi

    exit $code
  fi
done

exit 0
