generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// NextAuth Models
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// Core App Models
model User {
  id            String    @id @default(cuid())
  name          String?
  password      String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts                Account[]
  sessions                Session[]
  plaidItems              PlaidItem[]
  googleCalendarConnection GoogleCalendarConnection?
  financialAccounts       FinancialAccount[]
  transactions            Transaction[]
  recurringPatterns       RecurringPattern[]
  financialMemories       FinancialMemory[]
  dailyFinancialSnapshots DailyFinancialSnapshot[]
  financialGoals          FinancialGoal[]
  goalContributions       GoalContribution[]
  plaidApiLogs            PlaidApiLog[]
  growthActivities        GrowthActivity[]
  growthContacts          GrowthContact[]
  growthContactNotes      GrowthContactNote[]
  growthSnapshots         GrowthSnapshot[]
  growthRecommendations   GrowthRecommendation[]
  weeklyGrowthReviews     WeeklyGrowthReview[]
  growthOpportunities     GrowthOpportunity[]
  lifeLeverageProfile     LifeLeverageProfile?
  plannerDayLayouts       PlannerDayLayout[]
  carProfile              CarProfile?
  carMaintenanceLogs      CarMaintenanceLog[]
  calorieExperiments      CalorieExperiment[]
  calorieDayLogs          CalorieDayLog[]
  trendDigests            TrendDigest[]
  learningPlanSettings    LearningPlanSettings?
  learningContentItems    LearningContentItem[]
  learningYoutubeDigests  LearningYoutubeDigest[]
  coachSessions           CoachSession[]
  coachMessages           CoachMessage[]
}

model PlaidItem {
  id                   String   @id @default(cuid())
  userId               String
  institutionName      String?
  institutionId        String?
  plaidItemId          String   @unique
  encryptedAccessToken String
  cursor               String?
  status               String   @default("active")
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model GoogleCalendarConnection {
  id                    String    @id @default(cuid())
  userId                String    @unique
  calendarId            String    @default("primary")
  encryptedAccessToken  String    @db.Text
  encryptedRefreshToken String?   @db.Text
  accessTokenExpiresAt  DateTime?
  scopes                String[]
  status                String    @default("active") // active | needs_reconnect
  connectedAt           DateTime  @default(now())
  lastSyncAt            DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
}

model PlaidApiLog {
  id        String   @id @default(cuid())
  endpoint  String
  userId    String?
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)
}

model FinancialAccount {
  id               String   @id @default(cuid())
  userId           String
  plaidItemId      String
  plaidAccountId   String   @unique
  name             String
  officialName     String?
  type             String
  subtype          String?
  mask             String?
  currentBalance   Float?
  availableBalance Float?
  isoCurrencyCode  String?
  isPrimary        Boolean  @default(false)
  /// User-entered credit card details (Plaid does not reliably provide these)
  creditLimit      Float?
  aprPercent       Float?
  minimumPayment   Float?
  dueDay           Int?     // 1-31 day of month payment is due
  statementDay     Int?     // 1-31 statement close day
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Transaction {
  id                          String    @id @default(cuid())
  userId                      String
  plaidTransactionId          String    @unique
  accountId                   String
  date                        String    // YYYY-MM-DD
  authorizedDate              String?
  name                        String
  merchantName                String?
  amount                      Float
  isoCurrencyCode             String?
  pending                     Boolean   @default(false)
  categoryPrimary             String?
  categoryDetailed            String?
  customCategory              String?
  paymentChannel              String?
  isRecurringCandidate        Boolean   @default(false)
  isTenantPaymentCandidate    Boolean   @default(false)
  isUtilityCandidate          Boolean   @default(false)
  isFoodCandidate             Boolean   @default(false)
  isTransportationCandidate   Boolean   @default(false)
  isFlagged                   Boolean   @default(false)
  note                        String?   @db.Text
  createdAt                   DateTime  @default(now())
  updatedAt                   DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model RecurringPattern {
  id                    String   @id @default(cuid())
  userId                String
  merchantName          String?
  normalizedName        String
  category              String?
  averageAmount         Float
  frequency             String
  firstSeen             String
  lastSeen              String
  confidenceScore       Float
  direction             String   // "income" or "expense"
  exampleTransactionIds String[] // Array of transaction IDs
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model FinancialMemory {
  id               String   @id @default(cuid())
  userId           String
  type             String
  title            String
  content          String   @db.Text
  source           String
  importanceScore  Float
  pineconeVectorId String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model DailyFinancialSnapshot {
  id                  String   @id @default(cuid())
  userId              String
  date                String   // YYYY-MM-DD
  totalSpent          Float
  totalIncome         Float
  foodSpend           Float
  transportationSpend Float
  billsSpend          Float
  discretionarySpend  Float
  recurringSpend      Float
  accountBalanceTotal Float
  dailyScore          Float
  summary             String?  @db.Text
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
}

model FinancialGoal {
  id            String    @id @default(cuid())
  userId        String
  name          String
  targetAmount  Float
  currentAmount Float
  /// Planned recurring contribution (e.g. $15/mo from a canceled sub)
  monthlyContribution Float?
  targetDate    String?   // YYYY-MM-DD
  category      String?
  priority      Int       @default(3) // 1=High, 2=Medium, 3=Low
  status        String    @default("active") // "active", "completed", "abandoned"
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  user          User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  contributions GoalContribution[]
}

/// Logged principal / progress applied to a goal in a given month (debt paydown velocity).
model GoalContribution {
  id        String   @id @default(cuid())
  userId    String
  goalId    String
  /// Extra principal (or savings) applied — not minimum-only tread water.
  amount    Float
  /// Calendar month key YYYY-MM
  monthKey  String
  note      String?
  createdAt DateTime @default(now())

  user User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  goal FinancialGoal @relation(fields: [goalId], references: [id], onDelete: Cascade)

  @@index([goalId, monthKey])
  @@index([userId, monthKey])
}

// Growth Intelligence — high-leverage compounding across life domains
model GrowthActivity {
  id                    String   @id @default(cuid())
  userId                String
  date                  String // YYYY-MM-DD
  domain                String // career | startup | financial | social | fitness | personal
  category              String
  title                 String
  notes                 String?  @db.Text
  leverage              String   @default("long_term_leverage") // immediate_income | long_term_leverage
  minutesSpent          Int?
  impactScore           Float    @default(5) // 1-10
  /// planned | done | skipped — used for user_plan / planner checklist items
  status                String   @default("planned")
  /// Lower sorts earlier within a day's planner order for user_plan items
  sortOrder             Int      @default(100)
  /// Optional display time label (e.g. "7:30 AM" or "After work")
  timeLabel             String?
  /// Google Calendar event id when auto-logged from schedule
  sourceCalendarEventId String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, date])
  @@index([userId, sourceCalendarEventId])
}

/// Per-day planner layout: custom order + system-block overrides (complete / hide / rename)
model PlannerDayLayout {
  id            String   @id @default(cuid())
  userId        String
  date          String // YYYY-MM-DD
  /// Ordered refs: "user:<id>" | "system:<key>" | "calendar:<id>" | "week:<id>"
  orderJson     String   @default("[]") @db.Text
  /// { "lyft": { "status": "done"|"skipped"|"planned"|"hidden", "label"?, "timeLabel"?, "notes"? }, ... }
  overridesJson String   @default("{}") @db.Text
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId, date])
}

model GrowthContact {
  id                     String   @id @default(cuid())
  userId                 String
  name                   String
  relationshipType       String?
  trustLevel             Int      @default(3) // 1-5
  sharedInterests        String?
  collaborationPotential Int      @default(3) // 1-5
  lastContactDate        String? // YYYY-MM-DD
  suggestedNextAction    String?
  mutualValue            String?  @db.Text
  /// Legacy flat notes blob — kept for migration; prefer noteEntries
  notes                  String?  @db.Text
  status                 String   @default("active") // active | fading | dormant
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  user        User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  noteEntries GrowthContactNote[]

  @@index([userId, status])
}

/// Append-only timestamped notes (text and/or screenshot images) on a contact
model GrowthContactNote {
  id        String   @id @default(cuid())
  contactId String
  userId    String
  body      String?  @db.Text
  /// Data-URL screenshots (same pattern as chat image attachments)
  images    String[] @default([])
  createdAt DateTime @default(now())

  contact GrowthContact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  user    User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([contactId, createdAt])
  @@index([userId])
}

model GrowthSnapshot {
  id               String   @id @default(cuid())
  userId           String
  date             String // YYYY-MM-DD
  compoundingScore Float
  careerScore      Float    @default(0)
  startupScore     Float    @default(0)
  financialScore   Float    @default(0)
  socialScore      Float    @default(0)
  fitnessScore     Float    @default(0)
  personalScore    Float    @default(0)
  bottlenecks      String[]
  improving        Boolean  @default(false)
  metricsJson      String?  @db.Text
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
}

model GrowthRecommendation {
  id                  String   @id @default(cuid())
  userId              String
  date                String // YYYY-MM-DD
  action              String
  whyItMatters        String   @db.Text
  longTermBenefit     String   @db.Text
  timeRequiredMinutes Int      @default(60)
  opportunityCost     String   @db.Text
  relatedGoals        String[]
  relatedPeople       String[]
  nextActions         String[]
  leverageType        String   @default("long_term_leverage")
  domain              String?
  status              String   @default("pending") // pending | done | skipped
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
}

model WeeklyGrowthReview {
  id                    String   @id @default(cuid())
  userId                String
  weekStart             String // YYYY-MM-DD (Monday)
  whatWorked            String[]
  whatDidnt             String[]
  biggestReturn         String?  @db.Text
  timeWasted            String?  @db.Text
  stopDoing             String[]
  doMore                String[]
  relationshipsImproved String[]
  goalsBehind           String[]
  biggestBottleneck     String?  @db.Text
  adjustments           String[]
  compoundingScore      Float?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, weekStart])
}

model GrowthOpportunity {
  id            String    @id @default(cuid())
  userId        String
  title         String
  description   String    @db.Text
  domain        String?
  relatedPeople String[]
  urgency       String    @default("medium") // low | medium | high
  status        String    @default("open") // open | acted | dismissed
  detectedAt    DateTime  @default(now())
  expiresAt     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
}

model LifeLeverageProfile {
  id                    String   @id @default(cuid())
  userId                String   @unique
  promotionTarget       String?
  promotionDeadline     String?
  promotionUpsideAnnual Float?
  currentWeight         Float?
  targetWeight          Float?
  fitnessGoal           String?
  /// Deprecated — Lyft removed; kept so db push does not drop existing data.
  lyftHourlyNet         Float?
  lyftWeeklyProfitTarget  Float?
  lyftMonthlyProfitTarget Float?
  joyOptions            String[]
  notes                 String?  @db.Text
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

/// Owned-car obligations funded from Capital One (payment + insurance).
/// Also tracks loan payoff pace, odometer, and health/maintenance context.
model CarProfile {
  id                   String   @id @default(cuid())
  userId               String   @unique
  paymentMonthly       Float    @default(513)
  paymentNextDue       String // YYYY-MM-DD
  insuranceMonthly     Float    @default(352)
  insuranceNextDue     String // YYYY-MM-DD
  /// Original financed amount on the retail installment contract.
  loanAmount           Float    @default(26436)
  /// Remaining principal (editable as payments land).
  loanBalance          Float    @default(26436)
  /// Target payoff horizon in months (3.5 years = 42).
  loanTermMonths       Int      @default(42)
  /// When the loan / ownership clock started (YYYY-MM-DD).
  loanStartDate        String   @default("2026-07-01")
  /// Monthly amount Trell aims to put toward the loan (contract + extras).
  payoffTargetMonthly  Float    @default(800)
  /// Odometer at ownership / tracking start (lifespan baseline).
  startOdometerMiles   Float    @default(20323)
  /// Current odometer reading.
  odometerMiles        Float    @default(20323)
  /// When the odometer was last confirmed (YYYY-MM-DD).
  odometerAsOf         String   @default("2026-07-18")
  notes                String?  @db.Text
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  user            User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  maintenanceLogs CarMaintenanceLog[]
}

/// Service / neatness logs so the financed car stays healthy through payoff.
model CarMaintenanceLog {
  id             String   @id @default(cuid())
  userId         String
  carProfileId   String
  /// oil_change | tires | brakes | inspection | fluids | wash | other
  serviceType    String
  serviceDate    String // YYYY-MM-DD
  odometerMiles  Float?
  cost           Float?
  notes          String?  @db.Text
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  carProfile CarProfile @relation(fields: [carProfileId], references: [id], onDelete: Cascade)

  @@index([userId, serviceDate])
  @@index([carProfileId, serviceDate])
}

/// 3–4 week calorie experiment. Judge the week (budget), log the day.
model CalorieExperiment {
  id            String   @id @default(cuid())
  userId        String
  name          String   @default("Calorie experiment")
  /// Experiment start (YYYY-MM-DD). Weeks run Mon–Sun from this date's week.
  startDate     String
  durationWeeks Int      @default(4)
  /// Mon–Wed daily target (easier stick days).
  monWedTarget  Int      @default(2250)
  /// Thu–Sun daily target (looser weekend / harder stretch).
  thuSunTarget  Int      @default(2600)
  /// Weekly calorie budget: monWedTarget*3 + thuSunTarget*4 (default 17,150).
  weeklyBudget  Int      @default(17150)
  /// active | completed | abandoned
  status        String   @default("active")
  notes         String?  @db.Text
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user    User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  dayLogs CalorieDayLog[]

  @@index([userId, status])
  @@index([userId, startDate])
}

/// One calorie total per day for an experiment.
model CalorieDayLog {
  id           String   @id @default(cuid())
  userId       String
  experimentId String
  date         String // YYYY-MM-DD
  calories     Int
  notes        String?  @db.Text
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user       User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  experiment CalorieExperiment @relation(fields: [experimentId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([experimentId, date])
  @@index([userId, date])
}

/// Daily curated tech/AI signal digest — not a news firehose
model TrendDigest {
  id              String   @id @default(cuid())
  userId          String
  date            String // YYYY-MM-DD
  /// Legacy / overall focus (prefer tech when building)
  mainTitle       String
  mainWhy         String   @db.Text
  mainAction      String
  focusGuardrail  String   @db.Text
  techMainTitle   String?
  techMainWhy     String?  @db.Text
  techMainAction  String?
  dmvMainTitle    String?
  dmvMainWhy      String?  @db.Text
  dmvMainAction   String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user  User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  items TrendItem[]

  @@unique([userId, date])
  @@index([userId, date])
}

model TrendItem {
  id               String   @id @default(cuid())
  digestId         String
  title            String
  summary          String   @db.Text
  whyItMatters     String   @db.Text
  theme            String // ai_models | labs | infra | startup | hardware_software
  sourceLabel      String
  sourceUrl        String?
  relevanceScore   Float    @default(5)
  status           String   @default("new") // new | noted | parked | dismissed
  loggedActivityId String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  digest TrendDigest @relation(fields: [digestId], references: [id], onDelete: Cascade)

  @@index([digestId, status])
}

/// Drive-time learning mix + weekly hours (one row per user).
model LearningPlanSettings {
  id                   String   @id @default(cuid())
  userId               String   @unique
  /// Available learning / drive hours this week.
  weeklyHours          Float    @default(10)
  /// JSON map of category id → percentage (0–100). Must sum to 100 when valid.
  categoryPercentages  Json
  /// When true, daily YouTube picks are auto-added to the content queue.
  autoQueueYoutube     Boolean  @default(true)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

/// Queued learning content (podcasts, YouTube, articles) for drive time.
model LearningContentItem {
  id              String   @id @default(cuid())
  userId          String
  title           String
  url             String
  /// Matches LEARNING_CATEGORIES ids (e.g. startup_product, ai).
  category        String
  durationMinutes Int
  /// high | medium | low
  priority        String   @default("medium")
  /// saved | in_progress | completed | skipped
  status          String   @default("saved")
  /// manual | youtube_daily
  source          String   @default("manual")
  /// YouTube video id (or other external id) for dedupe.
  externalId      String?
  completedAt     DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([userId, category])
  @@index([userId, createdAt])
  @@index([userId, externalId])
}

/// Daily curated YouTube drive-time picks (real videos from channel RSS).
model LearningYoutubeDigest {
  id          String   @id @default(cuid())
  userId      String
  date        String // YYYY-MM-DD
  autoQueued  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user  User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  picks LearningYoutubePick[]

  @@unique([userId, date])
  @@index([userId, date])
}

model LearningYoutubePick {
  id               String   @id @default(cuid())
  digestId         String
  videoId          String
  title            String
  url              String
  channelLabel     String
  category         String
  durationMinutes  Int
  summary          String?  @db.Text
  relevanceScore   Float    @default(5)
  /// suggested | queued | skipped | played
  status           String   @default("suggested")
  queuedItemId     String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  digest LearningYoutubeDigest @relation(fields: [digestId], references: [id], onDelete: Cascade)

  @@index([digestId, status])
  @@index([videoId])
}

model CoachSession {
  id        String   @id @default(cuid())
  userId    String
  title     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages CoachMessage[]

  @@index([userId, updatedAt])
}

model CoachMessage {
  id                 String   @id @default(cuid())
  sessionId          String
  userId             String
  role               String // user | assistant
  content            String   @db.Text
  images             String[] @default([])
  spotlightJson      String?  @db.Text
  goalSuggestionJson String?  @db.Text
  createdAt          DateTime @default(now())

  session CoachSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user    User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([sessionId, createdAt])
  @@index([userId, createdAt])
}
